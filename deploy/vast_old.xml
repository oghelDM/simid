<VAST version="4.2">
    <Ad id="{campaignName}">
        <InLine>
            <AdSystem>StudioDM</AdSystem>
            <AdTitle>{campaignName}</AdTitle>
            <ViewableImpression/>
            <AdVerifications/>
            <Extensions/>
            <Creatives>
                <Creative id="{campaignName}c">
                    <Linear>
                        <Duration>00:00:15</Duration>
                        <TrackingEvents/>
                        <VideoClicks/>
                        <MediaFiles>
                            <MediaFile type="application/javascript" apiFramework="VPAID" maintainAspectRatio="true">
                                <![CDATA[ {indexUrl} ]]>
                            </MediaFile>
                            <MediaFile type="application/x-javascript" apiFramework="VPAID" maintainAspectRatio="true">
                                <![CDATA[ {indexUrl} ]]>
                            </MediaFile>
                        </MediaFiles>
                    </Linear>
                </Creative>
            </Creatives>
        </InLine>
    </Ad>
</VAST>
{
	"name": "creatives-framework",
	"version": "1.0.0",
	"description": "",
	"type": "commonjs",
	"config": {
		"creativePath": "simid/index.ts",
		"creativeYear": "2026",
		"creativeCampaign": "toto",
		"creativeDuration": "15",
		"creativeVersion": ""
	},
	"scripts": {
		"devq": "./node_modules/.bin/webpack serve --mode development --hot --port=8081 --entry=./src/creatives/$npm_package_config_creativePath",
		"dev": "./node_modules/.bin/webpack serve --mode development --hot --port=8080 --entry=./src/creatives/$npm_config_target",
		"dev3": "./node_modules/.bin/webpack serve --mode development --hot --port=8080 --entry=./src/creatives/examples/collectionMizuno.ts",
		"build": "webpack --mode production --entry=./src/creatives/$npm_config_target",
		"build2": "npm run build --target=2024/Entertainement_Paramount_Plus_Halo_Interactive_Countdown_2401_CAMPAIGN_FR_15s/creative.ts",
		"build3": "npm run build --target=examples/collectionMizuno.ts",
		"lint:check": "eslint . --ext .ts",
		"lint:fix": "eslint . --ext .ts --fix",
		"devv": "./node_modules/.bin/webpack serve --mode development --hot --port=8080 --entry=./src/creatives/$npm_package_config_creativeYear/$npm_package_config_creativeCampaign/creative.ts",
		"buildd": "npm run build --target=$npm_package_config_creativeYear/$npm_package_config_creativeCampaign/creative.ts",
		"deploy": "npm run build --target=$npm_package_config_creativeYear/$npm_package_config_creativeCampaign/creative.ts && gulp --year $npm_package_config_creativeYear --campaign $npm_package_config_creativeCampaign --creativeVersion $npm_package_config_creativeVersion --duration $npm_package_config_creativeDuration",
		"devTakeOver": "./node_modules/.bin/webpack serve --mode development --hot --port=8080 --entry=./src/takeOvers/$npm_package_config_creativeYear/$npm_package_config_creativeCampaign/creative.ts",
		"buildTakeOver": "webpack --mode production --entry=./src/takeOvers/$npm_config_target",
		"deployTakeOver": "npm run buildTakeOver --target=$npm_package_config_creativeYear/$npm_package_config_creativeCampaign/creative.ts && gulp --isTakeOver true --year $npm_package_config_creativeYear --campaign $npm_package_config_creativeCampaign --creativeVersion $npm_package_config_creativeVersion --duration $npm_package_config_creativeDuration"
	},
	"private": true,
	"dependencies": {
		"@types/three": "^0.159.0",
		"animejs": "^4.2.0",
		"dat.gui": "^0.7.9",
		"gsap": "^3.12.2",
		"openmeteo": "^1.1.3",
		"three": "^0.159.0"
	},
	"devDependencies": {
		"@types/dat.gui": "^0.7.12",
		"@types/node": "^20.9.4",
		"@typescript-eslint/eslint-plugin": "^6.12.0",
		"@typescript-eslint/parser": "^6.12.0",
		"copy-webpack-plugin": "^11.0.0",
		"eslint": "^8.54.0",
		"gulp": "^4.0.2",
		"gulp-modify-file": "^1.0.1",
		"gulp-rename": "^2.0.0",
		"gulp-replace": "^1.1.4",
		"gulp-util": "^3.0.8",
		"html-webpack-plugin": "^5.5.3",
		"terser-webpack-plugin": "^5.3.9",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.1",
		"tsconfig-paths-webpack-plugin": "^4.1.0",
		"typescript": "^5.2.2",
		"vinyl-ftp": "^0.6.1",
		"webpack": "^5.89.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^4.15.1"
	},
	"contributors": [
		{
			"name": "JOYE Oghel",
			"email": "oghel.joye@dailymotion.com"
		}
	]
}
